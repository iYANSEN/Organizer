{
  "name": "my-organizer",
  "version": "1.0.0",
  "description": "AI-powered personal organizer — email & file management with local Baby AI",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run api\" \"electron .\"",
    "api": "cd api && python -m uvicorn server:app --reload --port 5000",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.yourname.my-organizer",
    "productName": "My Organizer",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "keywords": ["ai", "organizer", "email", "files", "automation"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "electron-store": "^8.0.0",
    "node-imap": "^0.9.6",
    "mailparser": "^3.6.0",
    "chokidar": "^3.5.3",
    "axios": "^1.6.0",
    "python-shell": "^5.0.0"
  }
}
